{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "outDir": "./out/main",
    "rootDir": "./src/main",
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/main/**/*", "electron.vite.config.ts"]
}
